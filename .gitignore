# ==========================================================================
# notes-helper — .gitignore
# This is a CODE repo. Audio, models, and generated reports never get committed.
# ==========================================================================

# --------------------------------------------------------------------------
# 0. Project data directories (the convention — everything data lives here)
#    input/  = the sound files you drop in         (gitignored, keep folder)
#    output/ = everything notes-helper generates         (gitignored, keep folder)
# --------------------------------------------------------------------------
# Anchored to repo root (leading /) so they never match nested SOURCE dirs
# like src/notes_helper/outputs/ — an un-anchored `outputs/` once swallowed the code.
/input/
/output/
.private/
!/input/.gitkeep
!/output/.gitkeep

# --------------------------------------------------------------------------
# 1. Audio & media (raw inputs — always local, never in git; belt & suspenders)
# --------------------------------------------------------------------------
*.wav
*.mp3
*.m4a
*.aac
*.flac
*.opus
*.ogg
*.oga
*.wma
*.aiff
*.aif
*.caf
*.mp4
*.mov
*.mkv
*.webm
New Recording*.m4a

# --------------------------------------------------------------------------
# 2. Models & ML weights (pulled from Hugging Face on first run, not vendored)
# --------------------------------------------------------------------------
models/
.cache/
*.gguf
*.ggml
*.bin
*.pt
*.pth
*.onnx
*.safetensors
*.mlmodel
*.mlmodelc
*.mlpackage/
*.npz            # diarization checkpoints
*.npy

# --------------------------------------------------------------------------
# 3. Generated outputs (rendered from transcript.json + synthese.json)
# --------------------------------------------------------------------------
/out/
/outputs/
report.html
report.md
report.docx
report.pdf
report.pptx
*.docx
*.pptx
# pipeline artifacts
transcript*.json
transcript*.txt
synthese*.json
speaker_mapping.json
diar_checkpoint*.npz
pipeline*.log
*_done.txt
audio_16k*.wav

# generated meeting reports with bespoke run names (legacy + real executions)
*rapport*.htm*
compte-rendu*.md
*.jsonl
# stray screenshots / run images at repo root
cal.png
*.screenshot.png

# self-contained reports copy the assets dir next to themselves — ignore those copies,
# but NEVER ignore the source assets vendored inside the package (negation below).
/assets/
**/report_files/

# example run folders (self-contained outputs, kept out of the code repo)
cafe_premier_*/
reunion_seven_*/
*.zip

# --------------------------------------------------------------------------
# 4. On-device identity store (voiceprints — biometric, never leaves the machine)
# --------------------------------------------------------------------------
.notes-helper/
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# --------------------------------------------------------------------------
# 5. Secrets & local config (commit only the *.example templates)
# --------------------------------------------------------------------------
.env
.env.*
!.env.example
*config.json
!*config.json.example
*.pem
*.key
secrets.*
.secrets/
.pypirc
# local escape-hatch script (never committed)
nomoreclaude.sh

# --------------------------------------------------------------------------
# 6. Python
# --------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
build/
dist/
wheels/
*.whl
pip-wheel-metadata/
.installed.cfg
MANIFEST

# virtualenvs
.venv/
venv/
env/
ENV/
.python-version

# test / type / lint / coverage caches
.pytest_cache/
.mypy_cache/
.dmypy.json
.pyre/
.ruff_cache/
.tox/
.nox/
.hypothesis/
.coverage
.coverage.*
coverage.xml
htmlcov/
.cache/

# --------------------------------------------------------------------------
# 7. Notebooks
# --------------------------------------------------------------------------
.ipynb_checkpoints/
*-checkpoint.ipynb

# --------------------------------------------------------------------------
# 8. Node / front-end tooling (if a web/desktop shell is added later)
# --------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --------------------------------------------------------------------------
# 9. Editors & IDEs
# --------------------------------------------------------------------------
.idea/
.vscode/
!.vscode/extensions.json
*.swp
*.swo
*~
\#*\#
.\#*
*.sublime-project
*.sublime-workspace

# --------------------------------------------------------------------------
# 10. OS cruft
# --------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.fseventsd
.VolumeIcon.icns
.AppleDouble
.LSOverride
ehthumbs.db
Thumbs.db
desktop.ini

# --------------------------------------------------------------------------
# 11. Misc project junk
# --------------------------------------------------------------------------
*.log
logs/
tmp/
.tmp/
scratch/
.deepeval/

# --------------------------------------------------------------------------
# 12. Xcode / Swift apps (the .xcodeproj is generated from apps/project.yml)
# --------------------------------------------------------------------------
apps/NotesHelper.xcodeproj/
apps/build/
DerivedData/
*.xcuserstate
xcuserdata/
*.xcscmblueprint

# ==========================================================================
# Negations — keep these tracked despite the broad rules above
# ==========================================================================
# Vendored front-end assets shipped as package data (Tailwind + fonts).
!src/notes_helper/assets/
!src/notes_helper/assets/**
!.gitignore
!.env.example

settings.yaml
# session journal (kept local, like .private/)
/todo.md

# Landscape/positioning-map CSVs (generated from the star tables; the PNG
# positioning map is the committed artifact, not these intermediates).
