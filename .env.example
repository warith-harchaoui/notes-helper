# Copy to .env (git-ignored) and edit. Environment overrides notes_helper_config.json.
# All optional — Notes Helper runs on sane local defaults with no config at all.

# Local Ollama endpoint + model used for synthesis (must be running: `ollama serve`)
NOTES_HELPER_OLLAMA_URL=http://127.0.0.1:11434
NOTES_HELPER_OLLAMA_MODEL=qwen2.5:32b

# whisper.cpp model tag and default transcription language
NOTES_HELPER_WHISPER_MODEL=large-v3-turbo-q5_0
NOTES_HELPER_LANG=fr

# On-device voiceprint store (SQLite). Never synced unless you decide.
NOTES_HELPER_DB=~/.notes-helper/people.db

# Only if a gated Hugging Face model must be pulled on first run. Never commit a real token.
# HF_TOKEN=
